<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body style="background-color: #f9f9f9; font-family: sans-serif; margin: 0; padding: 0;">
  <div style="max-width: 400px; margin: 100px auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); border-top: 5px solid #f2690f;">
    <h2 style="color: #333; margin-top: 0; text-align: center;">Technician Portal</h2>
    <p style="color: #666; text-align: center; font-size: 14px; margin-bottom: 25px;">Log in to access clinic bookings and update reports</p>
    
    <% if (error) { %>
      <div style="background: #fff0f0; color: #d93838; padding: 12px; margin-bottom: 20px; border-radius: 4px; font-size: 14px; border: 1px solid #ffd1d1;">
        <%= error %>
      </div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div style="margin-bottom: 15px;">
        <label style="display: block; font-size: 14px; color: #555; margin-bottom: 5px; font-weight: bold;">Technician Email</label>
        <input type="email" name="email" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
      </div>
      
      <div style="margin-bottom: 25px;">
        <label style="display: block; font-size: 14px; color: #555; margin-bottom: 5px; font-weight: bold;">Password</label>
        <input type="password" name="password" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
      </div>

      <button type="submit" style="background: #f2690f; color: white; border: none; width: 100%; padding: 12px; font-size: 16px; font-weight: bold; border-radius: 4px; cursor: pointer; width: 100%;">
        Access Dashboard
      </button>
    </form>
    <p style="text-align: center; font-size: 14px; margin-top: 25px; color: #666; font-family: sans-serif;">
      Are you a patient? <a href="/login" style="color: #f2690f; text-decoration: none; font-weight: bold;">Patient Portal Log In</a>
    </p>
  </div>
</body>
</html>