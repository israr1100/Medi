<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="auth-shell">
    <div class="auth-shell__art">
      <h2>Welcome back.</h2>
      <p>Log in to check your appointment status, request a new test, or view a report that's ready.</p>
    </div>
    <div class="auth-shell__form">
      <div class="form-card">
        <h1>Log in</h1>
        <p class="form-card__sub">Access your patient portal.</p>

        <% if (error) { %>
          <div class="alert alert--error"><%= error %></div>
        <% } %>

        <form action="/login" method="POST">
          <div class="field">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email" value="<%= email %>" required />
          </div>
          <div class="field">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required />
          </div>
          <button type="submit" class="btn btn--primary btn--block">Log In</button>
        </form>

        <p class="form-card__foot">New to Medprime? <a href="/register">Create an account</a></p>
      </div>
    </div>
  </div>
</body>
</html>
