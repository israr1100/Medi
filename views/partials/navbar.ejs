<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">
      <span class="brand__mark">M+</span>
      <span class="brand__name">Medprime</span>
    </a>
    <nav class="site-nav">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>
    <div class="site-header__actions">
      <% if (isLoggedIn) { %>
        <a href="/portal/dashboard" class="btn btn--primary btn--sm">My Portal</a>
      <% } else if (isStaffLoggedIn) { %>
        <a href="/admin/dashboard" class="btn btn--primary btn--sm">Staff Dashboard</a>
      <% } else { %>
        <a href="/admin/login" class="btn btn--ghost btn--sm">Staff Login</a>
        <a href="/login" class="btn btn--ghost btn--sm">Log In</a>
        <a href="/register" class="btn btn--primary btn--sm">Register</a>
      <% } %>
    </div>
  </div>
</header>
